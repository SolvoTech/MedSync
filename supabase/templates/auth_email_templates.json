{
    "site_url": "https://givfjbxoqtougorolymn.supabase.co",
    "mailer_subjects_confirmation": "Konfirmasi akun MedSync Anda",
    "mailer_templates_confirmation_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px 24px 8px 24px;background:linear-gradient(135deg,#0ea5e9,#22c55e);color:#ffffff;\"><p style=\"margin:0;font-size:13px;letter-spacing:.4px;opacity:.95;\">MedSync</p><h1 style=\"margin:8px 0 0 0;font-size:22px;line-height:1.3;\">Konfirmasi Akun Anda</h1></td></tr><tr><td style=\"padding:24px;\">{{ if .Data.full_name }}<p style=\"margin:0 0 14px 0;font-size:16px;\">Halo {{ .Data.full_name }},</p>{{ else }}<p style=\"margin:0 0 14px 0;font-size:16px;\">Halo,</p>{{ end }}<p style=\"margin:0 0 18px 0;font-size:15px;line-height:1.6;\">Terima kasih sudah mendaftar di MedSync. Klik tombol di bawah untuk mengonfirmasi email Anda dan mulai menggunakan aplikasi.</p><p style=\"margin:0 0 20px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:12px 20px;background:#0ea5e9;color:#ffffff;text-decoration:none;border-radius:10px;font-weight:600;\">Konfirmasi Email</a></p><p style=\"margin:0 0 10px 0;font-size:13px;color:#6b7280;\">Jika tombol tidak berfungsi, salin tautan ini:</p><p style=\"margin:0;font-size:13px;word-break:break-all;color:#2563eb;\">{{ .ConfirmationURL }}</p></td></tr><tr><td style=\"padding:16px 24px 24px 24px;border-top:1px solid #e5e7eb;\"><p style=\"margin:0;font-size:12px;color:#6b7280;\">Email ini dikirim otomatis oleh MedSync untuk {{ .Email }}. Jika Anda tidak membuat akun, abaikan email ini.</p></td></tr></table></td></tr></table></div>",
    "mailer_subjects_invite": "Anda diundang ke MedSync",
    "mailer_templates_invite_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px 24px 8px 24px;background:linear-gradient(135deg,#0284c7,#14b8a6);color:#ffffff;\"><p style=\"margin:0;font-size:13px;letter-spacing:.4px;opacity:.95;\">MedSync</p><h1 style=\"margin:8px 0 0 0;font-size:22px;line-height:1.3;\">Undangan Bergabung</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 14px 0;font-size:16px;\">Halo,</p><p style=\"margin:0 0 18px 0;font-size:15px;line-height:1.6;\">Anda mendapatkan undangan untuk bergabung ke MedSync. Klik tombol berikut untuk menerima undangan dan melanjutkan.</p><p style=\"margin:0 0 20px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:12px 20px;background:#0ea5e9;color:#ffffff;text-decoration:none;border-radius:10px;font-weight:600;\">Terima Undangan</a></p><p style=\"margin:0;font-size:13px;color:#6b7280;\">Undangan ini ditujukan untuk {{ .Email }}.</p></td></tr></table></td></tr></table></div>",
    "mailer_subjects_magic_link": "Masuk ke MedSync via Magic Link",
    "mailer_templates_magic_link_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px 24px 8px 24px;background:linear-gradient(135deg,#0f766e,#10b981);color:#ffffff;\"><p style=\"margin:0;font-size:13px;letter-spacing:.4px;opacity:.95;\">MedSync</p><h1 style=\"margin:8px 0 0 0;font-size:22px;line-height:1.3;\">Magic Link Login</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 18px 0;font-size:15px;line-height:1.6;\">Klik tombol berikut untuk langsung masuk ke akun MedSync Anda.</p><p style=\"margin:0 0 20px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:12px 20px;background:#10b981;color:#ffffff;text-decoration:none;border-radius:10px;font-weight:600;\">Masuk Sekarang</a></p><p style=\"margin:0;font-size:13px;color:#6b7280;\">Jika Anda tidak meminta tautan login, abaikan email ini.</p></td></tr></table></td></tr></table></div>",
    "mailer_subjects_recovery": "Reset kata sandi MedSync",
    "mailer_templates_recovery_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px 24px 8px 24px;background:linear-gradient(135deg,#ef4444,#f97316);color:#ffffff;\"><p style=\"margin:0;font-size:13px;letter-spacing:.4px;opacity:.95;\">MedSync</p><h1 style=\"margin:8px 0 0 0;font-size:22px;line-height:1.3;\">Reset Kata Sandi</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 18px 0;font-size:15px;line-height:1.6;\">Kami menerima permintaan reset kata sandi untuk akun Anda. Klik tombol berikut untuk melanjutkan.</p><p style=\"margin:0 0 20px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:12px 20px;background:#ef4444;color:#ffffff;text-decoration:none;border-radius:10px;font-weight:600;\">Reset Kata Sandi</a></p><p style=\"margin:0;font-size:13px;color:#6b7280;\">Jika Anda tidak meminta reset, abaikan email ini.</p></td></tr></table></td></tr></table></div>",
    "mailer_subjects_reauthentication": "Kode verifikasi MedSync",
    "mailer_templates_reauthentication_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px 24px 8px 24px;background:linear-gradient(135deg,#2563eb,#06b6d4);color:#ffffff;\"><p style=\"margin:0;font-size:13px;letter-spacing:.4px;opacity:.95;\">MedSync</p><h1 style=\"margin:8px 0 0 0;font-size:22px;line-height:1.3;\">Verifikasi Ulang Diperlukan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 14px 0;font-size:15px;line-height:1.6;\">Gunakan kode berikut untuk menyelesaikan proses verifikasi:</p><p style=\"margin:0 0 18px 0;font-size:28px;letter-spacing:3px;font-weight:700;color:#0f172a;\">{{ .Token }}</p><p style=\"margin:0;font-size:13px;color:#6b7280;\">Jangan bagikan kode ini kepada siapa pun.</p></td></tr></table></td></tr></table></div>",
    "mailer_subjects_email_change": "Konfirmasi perubahan email MedSync",
    "mailer_templates_email_change_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px 24px 8px 24px;background:linear-gradient(135deg,#4f46e5,#06b6d4);color:#ffffff;\"><p style=\"margin:0;font-size:13px;letter-spacing:.4px;opacity:.95;\">MedSync</p><h1 style=\"margin:8px 0 0 0;font-size:22px;line-height:1.3;\">Konfirmasi Perubahan Email</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 14px 0;font-size:15px;line-height:1.6;\">Kami menerima permintaan untuk mengganti email akun Anda.</p><p style=\"margin:0 0 12px 0;font-size:14px;color:#374151;\">Email saat ini: <strong>{{ .Email }}</strong></p><p style=\"margin:0 0 18px 0;font-size:14px;color:#374151;\">Email baru: <strong>{{ .NewEmail }}</strong></p><p style=\"margin:0 0 20px 0;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;padding:12px 20px;background:#4f46e5;color:#ffffff;text-decoration:none;border-radius:10px;font-weight:600;\">Konfirmasi Perubahan</a></p><p style=\"margin:0;font-size:13px;color:#6b7280;\">Jika ini bukan Anda, segera ubah kata sandi akun Anda.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_password_changed_enabled": true,
    "mailer_subjects_password_changed_notification": "Kata sandi akun MedSync Anda telah diubah",
    "mailer_templates_password_changed_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 14px 0;font-size:15px;line-height:1.6;\">Kata sandi untuk akun <strong>{{ .Email }}</strong> baru saja diubah.</p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika Anda tidak melakukan perubahan ini, segera reset kata sandi dan cek aktivitas akun.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_email_changed_enabled": true,
    "mailer_subjects_email_changed_notification": "Email akun MedSync telah berubah",
    "mailer_templates_email_changed_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 10px 0;font-size:15px;line-height:1.6;\">Email akun Anda telah diperbarui.</p><p style=\"margin:0 0 8px 0;font-size:14px;\">Sebelumnya: <strong>{{ .OldEmail }}</strong></p><p style=\"margin:0 0 12px 0;font-size:14px;\">Sekarang: <strong>{{ .Email }}</strong></p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika perubahan ini tidak Anda lakukan, segera amankan akun Anda.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_phone_changed_enabled": true,
    "mailer_subjects_phone_changed_notification": "Nomor telepon akun MedSync telah berubah",
    "mailer_templates_phone_changed_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 8px 0;font-size:14px;\">Nomor lama: <strong>{{ .OldPhone }}</strong></p><p style=\"margin:0 0 12px 0;font-size:14px;\">Nomor baru: <strong>{{ .Phone }}</strong></p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika Anda tidak melakukan perubahan ini, segera hubungi tim dukungan.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_identity_linked_enabled": true,
    "mailer_subjects_identity_linked_notification": "Metode login baru ditautkan ke akun Anda",
    "mailer_templates_identity_linked_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 12px 0;font-size:15px;line-height:1.6;\">Metode login <strong>{{ .Provider }}</strong> telah ditautkan ke akun <strong>{{ .Email }}</strong>.</p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika Anda tidak melakukan tindakan ini, segera ubah kata sandi akun Anda.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_identity_unlinked_enabled": true,
    "mailer_subjects_identity_unlinked_notification": "Metode login dilepas dari akun Anda",
    "mailer_templates_identity_unlinked_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 12px 0;font-size:15px;line-height:1.6;\">Metode login <strong>{{ .Provider }}</strong> telah dilepas dari akun <strong>{{ .Email }}</strong>.</p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika Anda tidak melakukan tindakan ini, segera amankan akun Anda.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_mfa_factor_enrolled_enabled": true,
    "mailer_subjects_mfa_factor_enrolled_notification": "MFA baru diaktifkan pada akun Anda",
    "mailer_templates_mfa_factor_enrolled_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 12px 0;font-size:15px;line-height:1.6;\">Metode MFA baru (<strong>{{ .FactorType }}</strong>) telah ditambahkan ke akun <strong>{{ .Email }}</strong>.</p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika ini bukan Anda, segera matikan MFA tersebut dan ubah kata sandi.</p></td></tr></table></td></tr></table></div>",
    "mailer_notifications_mfa_factor_unenrolled_enabled": true,
    "mailer_subjects_mfa_factor_unenrolled_notification": "MFA dinonaktifkan dari akun Anda",
    "mailer_templates_mfa_factor_unenrolled_notification_content": "<div style=\"margin:0;padding:0;background:#f4f7fb;font-family:Arial,Helvetica,sans-serif;color:#1f2937;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f7fb;padding:24px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;overflow:hidden;border:1px solid #e5e7eb;\"><tr><td style=\"padding:24px;background:#0f172a;color:#ffffff;\"><h1 style=\"margin:0;font-size:20px;\">Notifikasi Keamanan</h1></td></tr><tr><td style=\"padding:24px;\"><p style=\"margin:0 0 12px 0;font-size:15px;line-height:1.6;\">Metode MFA (<strong>{{ .FactorType }}</strong>) telah dihapus dari akun <strong>{{ .Email }}</strong>.</p><p style=\"margin:0;font-size:14px;color:#6b7280;\">Jika Anda tidak melakukan ini, segera amankan akun Anda.</p></td></tr></table></td></tr></table></div>"
}
